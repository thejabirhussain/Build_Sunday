# ==============================================================================
# Environment Configuration Template for Build Sunday Q&A Bot
# ==============================================================================
# Copy this file to a new file named '.env' and fill in your actual settings.
#
# CRITICAL SECURITY WARNING: 
# NEVER commit your actual '.env' file containing secrets to version control.
# Add '.env' to your '.gitignore' file to keep your credentials private.

# 1. API Credentials
# Get your OpenAI API Key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Custom API Base URL for running local OpenAI-compatible endpoints (e.g. Ollama, LM Studio, vLLM)
# If set to a local endpoint (containing 'localhost' or '127.0.0.1'), OPENAI_API_KEY validation
# is bypassed and defaulted automatically.
# For Ollama: http://localhost:11434/v1
# For LM Studio: http://localhost:1234/v1
# API_BASE_URL=

# 2. Model Configuration
# Recommended models: 
# - 'gpt-4o-mini' (Fast, highly cost-effective, standard for most Q&A)
# - 'gpt-4o' (Extremely smart, more expensive)
# - Local models: 'llama3', 'llama2', 'mistral' (when running via Ollama/local provider)
DEFAULT_MODEL=gpt-4o-mini

# Max tokens to generate in a single response chunk (optional, default: 1024)
MAX_COMPLETION_TOKENS=1024

# Temperature controls the randomness of response (0.0 = deterministic/precise, 1.0 = creative)
TEMPERATURE=0.7

# 3. Resiliency Configuration
# Maximum number of retry attempts for transient API errors (rate limits, server errors)
MAX_RETRIES=3

# Initial delay in seconds before the first retry (exponential backoff will multiply this)
RETRY_MIN_DELAY=2.0

# Maximum delay in seconds between retries to prevent long wait loops
RETRY_MAX_DELAY=10.0

# Network timeout in seconds for API requests
API_TIMEOUT=30.0
